generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CANCELLED
}

enum PurchaseInvoiceStatus {
  PENDING
  CONFIRMED
}

enum TdsDepositStatus {
  PENDING
  DEPOSITED
}

enum ItemType {
  MATERIAL
  LABOUR
  SERVICE
}

enum ExpenseType {
  MATERIAL
  LABOUR
  SUBCONTRACTOR
  OVERHEAD
}

enum GstType {
  INTRA
  INTER
  NOGST
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

enum VoucherType {
  PURCHASE
  SALE
  PAYMENT
  RECEIPT
  JOURNAL
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
  CARD
  OTHER
}

enum Channel {
  BANK
  CASH
  ADJUSTMENT
}

enum VendorLegalType {
  INDIVIDUAL
  HUF
  FIRM
  COMPANY
  OTHER
}

enum AttachmentEntityType {
  EXPENSE
  PURCHASE_INVOICE
  CLIENT_INVOICE
  PAYMENT_VOUCHER
  LABOUR_PAYMENT
  TRANSACTION
  TENANT_PROFILE
}

enum StockDirection {
  IN
  OUT
}

enum StockReferenceType {
  PURCHASE_INVOICE
  MATERIAL_RECEIPT
  EXPENSE
  ADJUSTMENT
  ISSUE
  RETURN
}

enum MaterialOrderStatus {
  ORDERED
  PARTIALLY_DELIVERED
  DELIVERED
  CANCELLED
}

enum PayeeType {
  VENDOR
  LABOURER
  OTHER
}

enum FinanceAccountType {
  CASH
  BANK
  UPI
  CARD
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum PartnerRemunerationType {
  SALARY
  BONUS
  COMMISSION
  OTHER
}

enum PartnerTdsStatus {
  NOT_APPLICABLE
  TO_BE_DEDUCTED
  DEDUCTED_NOT_PAID
  PAID
}

enum AllocationDocumentType {
  CLIENT_INVOICE
  EXPENSE
  PURCHASE_INVOICE
}

model ProjectPaymentStage {
  id        String @id @default(cuid())
  tenantId  Int    @default(1)
  projectId String

  stageName   String
  scopeOfWork String?
  percent     Decimal? @db.Decimal(5, 2)

  expectedAmount Decimal @db.Decimal(14, 2)
  expectedBank   Decimal @default(0) @db.Decimal(14, 2)
  expectedCash   Decimal @default(0) @db.Decimal(14, 2)

  actualBank Decimal @default(0) @db.Decimal(14, 2)
  actualCash Decimal @default(0) @db.Decimal(14, 2)

  expectedDate DateTime? @db.Date
  actualDate   DateTime? @db.Date

  notes     String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  receipts Receipt[]

  @@index([tenantId])
  @@index([tenantId, projectId, sortOrder])
  @@index([tenantId, projectId, stageName])
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                    User[]
  clients                  Client[]
  clientContacts           ClientContact[]
  vendors                  Vendor[]
  projects                 Project[]
  items                    Item[]
  itemVendors              ItemVendor[]
  expenses                 Expense[]
  purchaseInvoices         PurchaseInvoice[]
  purchaseInvoiceLines     PurchaseInvoiceLine[]
  purchaseOrders           PurchaseOrder[]
  purchaseOrderLines       PurchaseOrderLine[]
  debitNotes               DebitNote[]
  materialOrders           MaterialOrder[]
  materialReceipts         MaterialReceipt[]
  clientInvoices           ClientInvoice[]
  receipts                 Receipt[]
  vendorPayments           VendorPayment[]
  ledgerAccounts           LedgerAccount[]
  ledgerEntries            LedgerEntry[]
  stockMovements           StockMovement[]
  labourers                Labourer[]
  paymentVouchers          PaymentVoucher[]
  attachments              Attachment[]
  financeAccounts          FinanceAccount[]
  txnCategories            TxnCategory[]
  transactions             Transaction[]
  projectPaymentStages     ProjectPaymentStage[]
  profile                  TenantProfile?
  transactionAllocations   TransactionAllocation[]
  labourSheets             LabourSheet[]
  labourSheetLines         LabourSheetLine[]
  partners                 Partner[]
  partnerRemunerations     PartnerRemuneration[]
  partnerDrawings          PartnerDrawing[]
  partnerTdsPayments       PartnerTdsPayment[]
  vendorTdsPayments        VendorTdsPayment[]
  projectProfitAllocations ProjectProfitAllocation[]
  auditLogs                AuditLog[]
}

model TenantProfile {
  id       String @id @default(cuid())
  tenantId Int    @unique @default(1)

  legalName String
  tradeName String?
  phone     String?
  email     String?
  address   String?
  gstin     String?
  pan       String?

  bankName      String?
  bankAccountNo String?
  bankIfsc      String?
  upiId         String?

  brandName    String?
  primaryColor String?
  accentColor  String?

  logoUrl      String?
  logoName     String?
  logoMimeType String?
  logoSize     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, gstin])
}

// --- Auth (NextAuth / Auth.js) ---
model User {
  id            String    @id @default(cuid())
  tenantId      Int       @default(1)
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(STAFF)
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Masters ---
model Client {
  id                   String  @id @default(cuid())
  tenantId             Int     @default(1)
  name                 String
  contactPerson        String?
  phone                String?
  email                String?
  billingAddress       String?
  siteAddress          String?
  gstin                String?
  pan                  String?
  paymentTermsDays     Int?
  preferredPaymentMode String?
  notes                String?

  ledgerAccountId String?        @unique
  ledgerAccount   LedgerAccount? @relation(fields: [ledgerAccountId], references: [id], onDelete: SetNull)

  projects       Project[]
  clientInvoices ClientInvoice[]
  transactions   Transaction[]
  contacts       ClientContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, gstin])
}

model ClientContact {
  id       String @id @default(cuid())
  tenantId Int    @default(1)

  clientId  String
  name      String
  role      String?
  phone     String?
  whatsapp  String?
  email     String?
  isPrimary Boolean @default(false)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, clientId, isPrimary])
}

model Vendor {
  id                String          @id @default(cuid())
  tenantId          Int             @default(1)
  name              String
  type              String?
  trade             String?
  tags              String[]        @default([])
  legalType         VendorLegalType @default(OTHER)
  gstin             String?
  pan               String?
  phone             String?
  email             String?
  address           String?
  beneficiaryName   String?
  bankName          String?
  bankBranch        String?
  bankAccountNumber String?
  ifscCode          String?
  upiId             String?
  isSubcontractor   Boolean         @default(false)
  active            Boolean         @default(true)

  // TDS (defaults per 194C; used for subcontractors by default)
  tdsApplicable      Boolean  @default(false)
  tdsSection         String   @default("194C")
  tdsRate            Decimal? @db.Decimal(5, 2)
  tdsOverrideRate    Decimal? @db.Decimal(5, 2)
  tdsThresholdSingle Decimal  @default(30000) @db.Decimal(14, 2)
  tdsThresholdAnnual Decimal  @default(100000) @db.Decimal(14, 2)
  // Optional single yearly threshold override for simplified setups.
  tdsThreshold       Decimal? @db.Decimal(14, 2)

  // Transporter exemption (if applicable)
  isTransporter           Boolean @default(false)
  transporterVehicleCount Int?

  ledgerAccountId String?        @unique
  ledgerAccount   LedgerAccount? @relation(fields: [ledgerAccountId], references: [id], onDelete: SetNull)

  expenses         Expense[]
  purchaseInvoices PurchaseInvoice[]
  purchaseOrders   PurchaseOrder[]
  materialOrders   MaterialOrder[]
  materialReceipts MaterialReceipt[]
  vendorPayments   VendorPayment[]
  tdsPayments      VendorTdsPayment[]
  transactions     Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  paymentVouchers PaymentVoucher[]
  itemVendors     ItemVendor[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, trade])
  @@index([tenantId, gstin])
}

model Project {
  id        String        @id @default(cuid())
  tenantId  Int           @default(1)
  name      String
  clientId  String
  location  String?
  startDate DateTime?     @db.Date
  endDate   DateTime?     @db.Date
  status    ProjectStatus @default(ACTIVE)
  remarks   String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  expenses               Expense[]
  purchaseInvoices       PurchaseInvoice[]
  purchaseInvoiceLines   PurchaseInvoiceLine[]
  purchaseOrders         PurchaseOrder[]
  materialOrders         MaterialOrder[]
  materialReceipts       MaterialReceipt[]
  clientInvoices         ClientInvoice[]
  ledgerEntries          LedgerEntry[]
  transactions           Transaction[]
  transactionAllocations TransactionAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  stockMovements           StockMovement[]
  paymentVouchers          PaymentVoucher[]
  attachments              Attachment[]
  paymentStages            ProjectPaymentStage[]
  labourSheets             LabourSheet[]
  partnerRemunerations     PartnerRemuneration[]
  partnerDrawings          PartnerDrawing[]
  projectProfitAllocations ProjectProfitAllocation[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
}

model Partner {
  id                  String   @id @default(cuid())
  tenantId            Int      @default(1)
  name                String
  pan                 String?
  profitRatio         Decimal  @default(0) @db.Decimal(5, 2)
  capitalContribution Decimal? @db.Decimal(14, 2)
  isActive            Boolean  @default(true)
  notes               String?

  remunerations PartnerRemuneration[]
  drawings      PartnerDrawing[]
  tdsPayments   PartnerTdsPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
}

model PartnerRemuneration {
  id          String                  @id @default(cuid())
  tenantId    Int                     @default(1)
  partnerId   String
  projectId   String?
  date        DateTime                @db.Date
  type        PartnerRemunerationType
  grossAmount Decimal                 @db.Decimal(14, 2)
  tdsRate     Decimal                 @default(10) @db.Decimal(5, 2)
  tdsAmount   Decimal                 @default(0) @db.Decimal(14, 2)
  netPayable  Decimal                 @db.Decimal(14, 2)
  paymentMode PaymentMode?
  paymentDate DateTime?               @db.Date
  tdsStatus   PartnerTdsStatus        @default(NOT_APPLICABLE)
  fy          String
  note        String?

  partner Partner  @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, partnerId, date])
  @@index([tenantId, projectId, date])
  @@index([tenantId, fy])
}

model PartnerDrawing {
  id        String      @id @default(cuid())
  tenantId  Int         @default(1)
  partnerId String
  projectId String?
  date      DateTime    @db.Date
  amount    Decimal     @db.Decimal(14, 2)
  mode      PaymentMode
  note      String?

  partner Partner  @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, partnerId, date])
  @@index([tenantId, projectId, date])
}

model PartnerTdsPayment {
  id            String    @id @default(cuid())
  tenantId      Int       @default(1)
  partnerId     String
  fy            String
  section       String    @default("194T")
  challanNo     String?
  periodFrom    DateTime? @db.Date
  periodTo      DateTime? @db.Date
  tdsPaidAmount Decimal   @db.Decimal(14, 2)
  paymentDate   DateTime  @db.Date
  note          String?

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, partnerId, paymentDate])
  @@index([tenantId, fy])
}

model VendorTdsPayment {
  id            String    @id @default(cuid())
  tenantId      Int       @default(1)
  vendorId      String
  fy            String
  section       String    @default("194C")
  challanNo     String?
  periodFrom    DateTime? @db.Date
  periodTo      DateTime? @db.Date
  tdsPaidAmount Decimal   @db.Decimal(14, 2)
  paymentDate   DateTime  @db.Date
  note          String?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, vendorId, paymentDate])
  @@index([tenantId, fy])
}

model ProjectProfitAllocation {
  id                  String  @id @default(cuid())
  tenantId            Int     @default(1)
  projectId           String
  fy                  String
  profitBeforePartner Decimal @db.Decimal(14, 2)
  totalPartnerRemu    Decimal @db.Decimal(14, 2)
  profitAfterRemu     Decimal @db.Decimal(14, 2)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, projectId, fy])
  @@index([tenantId])
  @@index([tenantId, projectId])
  @@index([tenantId, fy])
}

model Item {
  id             String   @id @default(cuid())
  tenantId       Int      @default(1)
  name           String
  type           ItemType
  category       String?
  unit           String?
  sacHsnCode     String?
  defaultGstRate Decimal? @db.Decimal(5, 2)
  gstRate        Decimal  @db.Decimal(5, 2)
  trackInventory Boolean  @default(false)
  reorderLevel   Decimal? @db.Decimal(14, 3)
  description    String?

  purchaseInvoiceLines PurchaseInvoiceLine[]
  itemVendors          ItemVendor[]
  materialOrders       MaterialOrder[]
  materialReceipts     MaterialReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, type])
}

model ItemVendor {
  id       String @id @default(cuid())
  tenantId Int    @default(1)
  itemId   String
  vendorId String

  createdAt DateTime @default(now())

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, itemId, vendorId])
  @@index([tenantId])
  @@index([tenantId, itemId])
  @@index([tenantId, vendorId])
}

// --- Transactions ---
model Expense {
  id              String         @id @default(cuid())
  tenantId        Int            @default(1)
  projectId       String
  vendorId        String?
  labourerId      String?
  date            DateTime       @db.Date
  amountBeforeTax Decimal        @db.Decimal(14, 2)
  cgst            Decimal        @default(0) @db.Decimal(14, 2)
  sgst            Decimal        @default(0) @db.Decimal(14, 2)
  igst            Decimal        @default(0) @db.Decimal(14, 2)
  totalAmount     Decimal        @db.Decimal(14, 2)
  paymentStatus   String?
  paymentMode     PaymentMode?
  narration       String?
  expenseType     ExpenseType
  approvalStatus  ApprovalStatus @default(APPROVED)

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  vendor   Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  labourer Labourer? @relation(fields: [labourerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, projectId, date])
  @@index([tenantId, vendorId, date])
  @@index([tenantId, labourerId, date])
  @@index([tenantId, expenseType])
  @@index([tenantId, approvalStatus])
}

model Labourer {
  id       String  @id @default(cuid())
  tenantId Int     @default(1)
  name     String
  phone    String?
  address  String?
  active   Boolean @default(true)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  paymentVouchers PaymentVoucher[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, active])
}

model StockMovement {
  id            String             @id @default(cuid())
  tenantId      Int                @default(1)
  projectId     String
  itemId        String
  date          DateTime           @db.Date
  direction     StockDirection
  quantity      Decimal            @db.Decimal(14, 3)
  unitCost      Decimal?           @db.Decimal(14, 2)
  stageName     String?
  referenceType StockReferenceType
  referenceId   String?
  remarks       String?

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  item            Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  materialReceipt MaterialReceipt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, projectId, date])
  @@index([tenantId, itemId, date])
  @@index([tenantId, referenceType, referenceId])
}

model PaymentVoucher {
  id          String      @id @default(cuid())
  tenantId    Int         @default(1)
  payeeType   PayeeType
  vendorId    String?
  labourerId  String?
  payeeName   String?
  projectId   String?
  date        DateTime    @db.Date
  mode        PaymentMode
  reference   String?
  grossAmount Decimal     @db.Decimal(14, 2)
  tdsSection  String?
  tdsRate     Decimal?    @db.Decimal(5, 2)
  tdsAmount   Decimal?    @db.Decimal(14, 2)
  netPaid     Decimal     @db.Decimal(14, 2)
  narration   String?

  vendor   Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  labourer Labourer? @relation(fields: [labourerId], references: [id], onDelete: SetNull)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, payeeType, date])
  @@index([tenantId, vendorId, date])
  @@index([tenantId, labourerId, date])
  @@index([tenantId, projectId, date])
}

model Attachment {
  id         String               @id @default(cuid())
  tenantId   Int                  @default(1)
  entityType AttachmentEntityType
  entityId   String
  projectId  String?

  originalName String
  mimeType     String
  size         Int
  storagePath  String

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, projectId, createdAt])
}

model FinanceAccount {
  id       String             @id @default(cuid())
  tenantId Int                @default(1)
  name     String
  type     FinanceAccountType
  active   Boolean            @default(true)

  outgoingTransactions Transaction[] @relation("TxnFromAccount")
  incomingTransactions Transaction[] @relation("TxnToAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, active])
}

model TxnCategory {
  id       String          @id @default(cuid())
  tenantId Int             @default(1)
  name     String
  type     TransactionType
  active   Boolean         @default(true)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, type, name])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, active])
}

model Transaction {
  id                String           @id @default(cuid())
  tenantId          Int              @default(1)
  type              TransactionType
  date              DateTime         @db.Date
  amount            Decimal          @db.Decimal(14, 2)
  tdsAmount         Decimal          @default(0) @db.Decimal(14, 2)
  // Taxable base amount used for TDS threshold checks (e.g. 194C taxable value).
  tdsBaseAmount     Decimal          @default(0) @db.Decimal(14, 2)
  projectId         String?
  clientId          String?
  vendorId          String?
  categoryId        String?
  fromAccountId     String?
  toAccountId       String?
  mode              PaymentMode?
  channel           Channel          @default(BANK)
  reference         String?
  note              String?
  description       String?
  approvalStatus    ApprovalStatus   @default(APPROVED)
  tdsSection        String?
  tdsDepositStatus  TdsDepositStatus @default(PENDING)
  tdsChallanCin     String?
  tdsChallanBsrCode String?
  tdsChallanNumber  String?
  tdsChallanDate    DateTime?        @db.Date

  project     Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client      Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  vendor      Vendor?                 @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  category    TxnCategory?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  fromAccount FinanceAccount?         @relation("TxnFromAccount", fields: [fromAccountId], references: [id], onDelete: SetNull)
  toAccount   FinanceAccount?         @relation("TxnToAccount", fields: [toAccountId], references: [id], onDelete: SetNull)
  allocations TransactionAllocation[]
  receipts    Receipt[]
  labourSheet LabourSheet?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, type, date])
  @@index([tenantId, projectId, date])
  @@index([tenantId, clientId, date])
  @@index([tenantId, vendorId, date])
  @@index([tenantId, fromAccountId, date])
  @@index([tenantId, toAccountId, date])
  @@index([tenantId, categoryId, date])
  @@index([tenantId, mode, date])
  @@index([tenantId, approvalStatus])
  @@index([tenantId, tdsDepositStatus])
  @@index([tenantId, tdsChallanDate])
}

model TransactionAllocation {
  id            String @id @default(cuid())
  tenantId      Int    @default(1)
  transactionId String

  documentType AllocationDocumentType
  documentId   String
  projectId    String?

  cashAmount  Decimal @db.Decimal(14, 2)
  tdsAmount   Decimal @default(0) @db.Decimal(14, 2)
  grossAmount Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, transactionId])
  @@index([tenantId, documentType, documentId])
  @@index([tenantId, projectId, createdAt])
}

model LabourSheet {
  id             String         @id @default(cuid())
  tenantId       Int            @default(1)
  projectId      String
  date           DateTime       @db.Date
  mode           PaymentMode
  reference      String?
  note           String?
  total          Decimal        @db.Decimal(14, 2)
  approvalStatus ApprovalStatus @default(APPROVED)

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  lines LabourSheetLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, projectId, date])
  @@index([tenantId, approvalStatus])
}

model LabourSheetLine {
  id            String  @id @default(cuid())
  tenantId      Int     @default(1)
  labourSheetId String
  role          String
  headcount     Int     @default(1)
  rate          Decimal @db.Decimal(14, 2)
  amount        Decimal @db.Decimal(14, 2)

  labourSheet LabourSheet @relation(fields: [labourSheetId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, labourSheetId])
}

model PurchaseInvoice {
  id            String   @id @default(cuid())
  tenantId      Int      @default(1)
  vendorId      String
  invoiceNumber String
  invoiceDate   DateTime @db.Date
  projectId     String
  gstType       GstType
  gstRate       Decimal? @db.Decimal(5, 2)

  taxableValue Decimal @db.Decimal(14, 2)
  cgst         Decimal @default(0) @db.Decimal(14, 2)
  sgst         Decimal @default(0) @db.Decimal(14, 2)
  igst         Decimal @default(0) @db.Decimal(14, 2)
  total        Decimal @db.Decimal(14, 2)

  tdsApplicable  Boolean               @default(false)
  tdsSection     String?
  tdsRate        Decimal?              @db.Decimal(5, 2)
  tdsAmount      Decimal?              @db.Decimal(14, 2)
  netPayable     Decimal?              @db.Decimal(14, 2)
  approvalStatus ApprovalStatus        @default(APPROVED)
  invoiceStatus  PurchaseInvoiceStatus @default(CONFIRMED)

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  purchaseOrderId String?

  purchaseOrder    PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  lines            PurchaseInvoiceLine[]
  payments         VendorPayment[]
  materialReceipts MaterialReceipt[]
  debitNotes       DebitNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, vendorId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, vendorId, invoiceDate])
  @@index([tenantId, projectId, invoiceDate])
  @@index([tenantId, approvalStatus])
  @@index([tenantId, invoiceStatus])
  @@index([tenantId, purchaseOrderId])
}

model MaterialOrder {
  id        String @id @default(cuid())
  tenantId  Int    @default(1)
  projectId String
  vendorId  String
  itemId    String

  orderDate            DateTime            @db.Date
  expectedDeliveryDate DateTime?           @db.Date
  quantityOrdered      Decimal             @db.Decimal(14, 3)
  rate                 Decimal?            @db.Decimal(14, 2)
  amount               Decimal?            @db.Decimal(14, 2)
  status               MaterialOrderStatus @default(ORDERED)
  stageName            String?
  reference            String?
  remarks              String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  item    Item    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  receipts MaterialReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, projectId, orderDate])
  @@index([tenantId, vendorId, orderDate])
  @@index([tenantId, itemId, orderDate])
  @@index([tenantId, status])
}

model MaterialReceipt {
  id        String @id @default(cuid())
  tenantId  Int    @default(1)
  projectId String
  vendorId  String
  itemId    String

  materialOrderId   String?
  purchaseInvoiceId String?
  stockMovementId   String? @unique

  receiptDate   DateTime @db.Date
  challanNumber String?
  quantity      Decimal  @db.Decimal(14, 3)
  unitCost      Decimal? @db.Decimal(14, 2)
  amount        Decimal? @db.Decimal(14, 2)
  stageName     String?
  vehicleNumber String?
  remarks       String?

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  vendor          Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  item            Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  materialOrder   MaterialOrder?   @relation(fields: [materialOrderId], references: [id], onDelete: SetNull)
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)
  stockMovement   StockMovement?   @relation(fields: [stockMovementId], references: [id], onDelete: SetNull)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, projectId, receiptDate])
  @@index([tenantId, vendorId, receiptDate])
  @@index([tenantId, itemId, receiptDate])
  @@index([tenantId, materialOrderId])
  @@index([tenantId, purchaseInvoiceId])
}

model PurchaseInvoiceLine {
  id                String  @id @default(cuid())
  tenantId          Int     @default(1)
  purchaseInvoiceId String
  itemId            String
  quantity          Decimal @db.Decimal(14, 3)
  rate              Decimal @db.Decimal(14, 2)
  amount            Decimal @db.Decimal(14, 2)
  projectId         String

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, purchaseInvoiceId])
  @@index([tenantId, projectId])
}

model ClientInvoice {
  id                   String    @id @default(cuid())
  tenantId             Int       @default(1)
  clientId             String
  projectId            String
  invoiceNumber        String
  invoiceDate          DateTime  @db.Date
  dueDate              DateTime? @db.Date
  serviceDescription   String?
  sacCode              String?
  gstRate              Decimal?  @db.Decimal(5, 2)
  basicValue           Decimal   @db.Decimal(14, 2)
  gstType              GstType
  cgst                 Decimal   @default(0) @db.Decimal(14, 2)
  sgst                 Decimal   @default(0) @db.Decimal(14, 2)
  igst                 Decimal   @default(0) @db.Decimal(14, 2)
  total                Decimal   @db.Decimal(14, 2)
  tdsRate              Decimal?  @db.Decimal(5, 2)
  tdsAmountExpected    Decimal?  @db.Decimal(14, 2)
  receivedAmount       Decimal   @default(0) @db.Decimal(14, 2)
  tdsCertificateNumber String?
  status               String

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, projectId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, clientId, invoiceDate])
  @@index([tenantId, projectId, invoiceDate])
  @@index([tenantId, status])
}

model Receipt {
  id                    String         @id @default(cuid())
  tenantId              Int            @default(1)
  clientInvoiceId       String
  transactionId         String?
  projectPaymentStageId String?
  date                  DateTime       @db.Date
  amountReceived        Decimal        @db.Decimal(14, 2)
  mode                  PaymentMode
  channel               Channel        @default(BANK)
  reference             String?
  tdsDeducted           Boolean        @default(false)
  tdsAmount             Decimal?       @db.Decimal(14, 2)
  remarks               String?
  approvalStatus        ApprovalStatus @default(APPROVED)

  clientInvoice       ClientInvoice        @relation(fields: [clientInvoiceId], references: [id], onDelete: Cascade)
  transaction         Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  projectPaymentStage ProjectPaymentStage? @relation(fields: [projectPaymentStageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, clientInvoiceId, date])
  @@index([tenantId, transactionId])
  @@index([tenantId, projectPaymentStageId, date])
  @@index([tenantId, approvalStatus])
}

model VendorPayment {
  id                String      @id @default(cuid())
  tenantId          Int         @default(1)
  vendorId          String
  purchaseInvoiceId String?
  date              DateTime    @db.Date
  amountPaid        Decimal     @db.Decimal(14, 2)
  mode              PaymentMode
  reference         String?
  tdsDeducted       Boolean     @default(false)
  tdsAmount         Decimal?    @db.Decimal(14, 2)
  remarks           String?

  vendor          Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, vendorId, date])
  @@index([tenantId, purchaseInvoiceId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   Int      @default(1)
  userId     String?
  userEmail  String?
  action     String
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([tenantId, action, createdAt])
  @@index([tenantId, entityType, entityId, createdAt])
}

// --- Accounting ---
model LedgerAccount {
  id       String            @id @default(cuid())
  tenantId Int               @default(1)
  name     String
  type     LedgerAccountType
  group    String?

  clients Client[]
  vendors Vendor[]

  debitEntries  LedgerEntry[] @relation("LedgerDebit")
  creditEntries LedgerEntry[] @relation("LedgerCredit")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
}

model LedgerEntry {
  id              String      @id @default(cuid())
  tenantId        Int         @default(1)
  date            DateTime    @db.Date
  voucherType     VoucherType
  voucherId       String
  debitAccountId  String
  creditAccountId String
  amount          Decimal     @db.Decimal(14, 2)
  narration       String?
  projectId       String?

  debitAccount  LedgerAccount @relation("LedgerDebit", fields: [debitAccountId], references: [id], onDelete: Restrict)
  creditAccount LedgerAccount @relation("LedgerCredit", fields: [creditAccountId], references: [id], onDelete: Restrict)
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, voucherType, voucherId])
  @@index([tenantId, projectId, date])
}

// ─── Debit Notes ─────────────────────────────────────────────────────────────

model DebitNote {
  id                String   @id @default(cuid())
  tenantId          Int      @default(1)
  purchaseInvoiceId String
  debitNoteNumber   String
  date              DateTime @db.Date
  reason            String
  taxableValue      Decimal  @db.Decimal(14, 2)
  cgst              Decimal  @default(0) @db.Decimal(14, 2)
  sgst              Decimal  @default(0) @db.Decimal(14, 2)
  igst              Decimal  @default(0) @db.Decimal(14, 2)
  total             Decimal  @db.Decimal(14, 2)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, purchaseInvoiceId])
  @@index([tenantId, date])
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_BILLED
  FULLY_BILLED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    Int                 @default(1)
  vendorId    String
  projectId   String
  orderNumber String
  orderDate   DateTime            @db.Date
  status      PurchaseOrderStatus @default(DRAFT)
  notes       String?

  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  lines            PurchaseOrderLine[]
  purchaseInvoices PurchaseInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, vendorId, orderDate])
  @@index([tenantId, projectId, orderDate])
  @@index([tenantId, status])
}

model PurchaseOrderLine {
  id              String  @id @default(cuid())
  tenantId        Int     @default(1)
  purchaseOrderId String
  description     String
  unit            String?
  quantity        Decimal @db.Decimal(14, 3)
  rate            Decimal @db.Decimal(14, 2)
  amount          Decimal @db.Decimal(14, 2)
  sortOrder       Int     @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, purchaseOrderId])
}
